generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  Int                  @id @default(autoincrement())
  name                String
  email               String               @unique
  password            String
  department          String?
  role                Role                 @default(GENERAL_VIEWER)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  eventsCreated       Event[]
  memberships         Membership[]
  notifications       Notification[]
  rsvps               RSVP[]
  activities          Activity[]
  announcements       Announcement[]
  chatMessages        ChatMessage[]
  deletedChatMessages DeletedChatMessage[]
  mentions            Mention[]

  avatarUrl String?
  bio       String?
  phone     String?
  lastSeen  DateTime?
  isOnline  Boolean   @default(false)

  googleAccount GoogleAccount?
  googleAccessToken String?
  googleRefreshToken String?
  googleTokenExpiry DateTime?

  preferences     Json?
  auditLogs       AuditLog[]
  searchHistories SearchHistory[]
  userSessions    UserSession[]
  loginHistories  LoginHistory[]
}

model Club {
  id   Int     @id @default(autoincrement())
  name String  @unique
  slug String? @unique

  description String?
  about       String?
  tagline     String?
  motto       String?

  logoUrl   String?
  bannerUrl String?

  primaryColor   String @default("#2563eb")
  secondaryColor String @default("#1d4ed8")
  accentColor    String @default("#60a5fa")

  verified   Boolean   @default(false)
  verifiedAt DateTime?

  website   String?
  email     String?
  github    String?
  instagram String?
  linkedin  String?
  youtube   String?
  discord   String?

  established Int?
  foundedBy   String?
  location    String?
  settings    Json?

  isRecruiting Boolean @default(true)

  category ClubCategory @default(OTHER)

  createdAt DateTime  @default(now())
  updatedAt DateTime?

  coverVideo String?

  memberCount Int @default(0)
  eventCount  Int @default(0)

  chatEnabled Boolean @default(true)
  taskEnabled Boolean @default(true)

  features Json?

  events        Event[]
  memberships   Membership[]
  announcements Announcement[]
  activities    Activity[]
  committees    Committee[]
  tags          ClubTagAssignment[]
  chatRooms     ChatRoom[]
  chatMessages  ChatMessage[]
  tasks         Task[]
  taskLabels    TaskLabel[]
  deletedAt     DateTime?
  auditLogs     AuditLog[]
}

model ClubTag {
  id   Int    @id @default(autoincrement())
  name String @unique

  clubs ClubTagAssignment[]
}

model ClubTagAssignment {
  clubId Int
  tagId  Int

  club Club    @relation(fields: [clubId], references: [id])
  tag  ClubTag @relation(fields: [tagId], references: [id])

  @@id([clubId, tagId])
}

model Committee {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  color       String? @default("#2563eb")
  icon        String?
  isCore      Boolean @default(false)

  clubId Int
  club   Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  order Int @default(0)

  members CommitteeMember[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tasks     Task[]
  meetings  CommitteeMeeting[]
  chatRooms ChatRoom[]

  @@unique([clubId, name])
  @@index([clubId])
}

model CommitteeMember {
  id            Int           @id @default(autoincrement())
  committeeId   Int
  membershipId  Int
  role          CommitteeRole @default(MEMBER)
  joinedAt      DateTime      @default(now())
  committee     Committee     @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  membership    Membership    @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  assignedTasks Task[]        @relation("TaskAssignment")

  @@unique([committeeId, membershipId])
  @@index([membershipId])
  @@index([committeeId])
}

model MeetingSummary{

  id Int @id @default(autoincrement())
  meetingId Int

  transcript String?

  summary String

  actionItems Json?

  decisions Json?

  nextSteps Json?

  generatedByAI Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  meeting CommitteeMeeting @relation(fields:[meetingId],references:[id],onDelete:Cascade)

  @@unique([meetingId])

}

model CommitteeMeeting {
  id Int @id @default(autoincrement())

  title       String
  description String?
  agenda      String?

  startTime DateTime
  endTime   DateTime?

  status MeetingStatus @default(SCHEDULED)

  isInstant Boolean @default(false)

  meetingProvider MeetingProvider @default(GOOGLE_MEET)

  meetingCode String?
  onlineLink  String?

  location String?

  calendarEventId String?

  organizerId Int

  committeeId Int

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  committee Committee @relation(fields: [committeeId], references: [id], onDelete: Cascade)

  organizer Membership @relation("MeetingOrganizer", fields: [organizerId], references: [id])

  meetingProvider MeetingProvider @default(GOOGLE_MEET)

  calendarEventId String?

  meetingCode String?

  aiSummaryStatus SummaryStatus @default(PENDING)

  attendees MeetingAttendance[]

  summaries MeetingSummary[]

  recordings MeetingRecording[]

  notes MeetingNote[]

  attachments MeetingAttachment[]

  polls MeetingPoll[]

  @@index([committeeId])
  @@index([startTime])
  @@index([status])
}

model MeetingAttendance {
  id           Int @id @default(autoincrement())
  meetingId    Int
  membershipId Int

  status MeetingAttendanceStatus @default(PENDING)

  joinedAt DateTime?
  leftAt   DateTime?

  duration Int?

  meeting CommitteeMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([meetingId, membershipId])
}

model MeetingNote {
  id           Int @id @default(autoincrement())
  meetingId    Int
  membershipId Int

  note String

  createdAt DateTime @default(now())

  meeting CommitteeMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  membership Membership @relation(fields: [membershipId], references: [id])
}

model MeetingRecording {
  id           Int    @id @default(autoincrement())
  meetingId    Int
  recordingUrl String

  duration Int?

  createdAt DateTime @default(now())

  meeting CommitteeMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model MeetingAttachment {
  id           Int @id @default(autoincrement())
  meetingId    Int
  uploadedById Int

  fileName String
  fileUrl  String

  storageProvider String?
  bucket          String?
  storagePath     String?

  checksum String?

  mimeType String?

  size Int?

  createdAt DateTime @default(now())

  meeting CommitteeMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  uploader Membership @relation(fields: [uploadedById], references: [id])
}

model MeetingPoll {
  id        Int @id @default(autoincrement())
  meetingId Int

  question String

  multipleChoice Boolean @default(false)

  createdById Int

  isClosed Boolean @default(false)

  createdAt DateTime @default(now())

  meeting CommitteeMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  creator Membership @relation(fields: [createdById], references: [id])

  options MeetingPollOption[]
}

model MeetingPollOption {
  id     Int @id @default(autoincrement())
  pollId Int

  option String

  votes Int @default(0)

  poll MeetingPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
}

model Membership {
  id       Int              @id @default(autoincrement())
  userId   Int
  clubId   Int
  status   MembershipStatus @default(PENDING)
  clubRole ClubRole         @default(MEMBER)
  joinedAt DateTime         @default(now())
  leftAt   DateTime?
  club     Club             @relation(fields: [clubId], references: [id])
  user     User             @relation(fields: [userId], references: [id])

  nickname          String?
  muteNotifications Boolean   @default(false)
  lastVisitedAt     DateTime?
  joinedById        Int?

  committeeMemberships CommitteeMember[]
  createdTasks         Task[]                @relation("TaskCreator")
  taskComments         TaskComment[]
  attachments          TaskAttachment[]
  commentReactions     TaskCommentReaction[]
  organizedMeetings    CommitteeMeeting[]    @relation("MeetingOrganizer")
  meetingAttendances   MeetingAttendance[]
  chatMessages         ChatMessage[]
  chatReactions        ChatReaction[]
  chatReads            ChatRead[]            @relation
  starredMessages      StarredMessage[]
  savedMessages        SavedMessage[]
  chatThreads          ChatThread[]
  chatThreadReactions  ChatThreadReaction[]
  chatPins             ChatPin[]
  pinnedMessages       PinnedMessage[]
  taskActivities       TaskActivity[]
  watchedTasks         TaskWatcher[]
  uploadHistories      UploadHistory[]
  meetingNotes         MeetingNote[]
  meetingAttachments   MeetingAttachment[]
  meetingPolls         MeetingPoll[]

  @@unique([userId, clubId])
}

model Event {
  id          Int       @id @default(autoincrement())
  title       String
  description String
  startTime   DateTime
  endTime     DateTime
  location    String
  visibility  Boolean   @default(true)
  clubId      Int
  createdById Int
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?
  club        Club      @relation(fields: [clubId], references: [id])
  creator     User      @relation(fields: [createdById], references: [id])
  rsvps       RSVP[]

  @@index([clubId])
  @@index([createdById])
  @@index([startTime])
}

model RSVP {
  id        Int        @id @default(autoincrement())
  userId    Int
  eventId   Int
  status    RSVPStatus
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id])
  event     Event      @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
}

model Notification {
  id      Int    @id @default(autoincrement())
  title   String
  message String

  type     NotificationType
  category NotificationCategory
  priority NotificationPriority @default(NORMAL)

  icon String?

  imageUrl  String?
  actionUrl String?

  actionText String?
  entityType String?

  entityId Int?
  clubId   Int?
  senderId Int?
  userId   Int

  isRead Boolean   @default(false)
  readAt DateTime?

  deliveredAt DateTime?
  expiresAt   DateTime?

  metadata Json?

  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Announcement {
  id          Int      @id @default(autoincrement())
  title       String
  content     String
  clubId      Int
  createdById Int
  createdAt   DateTime @default(now())
  club        Club     @relation(fields: [clubId], references: [id])
  creator     User     @relation(fields: [createdById], references: [id])
}

model Activity {
  id          Int      @id @default(autoincrement())
  action      String
  description String
  clubId      Int
  userId      Int?
  createdAt   DateTime @default(now())
  club        Club     @relation(fields: [clubId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])
  entityType  String?
  entityId    Int?
  metadata    Json?

  @@index([clubId])
  @@index([createdAt])
}

model Task {
  id Int @id @default(autoincrement())

  title       String
  description String?

  status   TaskStatus   @default(TODO)
  priority TaskPriority @default(MEDIUM)

  dueDate     DateTime?
  completedAt DateTime?

  estimatedHours Float?

  position Int @default(0)

  isArchived Boolean @default(false)

  committeeId  Int
  assignedToId Int?
  createdById  Int

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  committee  Committee        @relation(fields: [committeeId], references: [id])
  assignedTo CommitteeMember? @relation("TaskAssignment", fields: [assignedToId], references: [id])
  createdBy  Membership       @relation("TaskCreator", fields: [createdById], references: [id])

  comments    TaskComment[]
  attachments TaskAttachment[]
  labels      TaskLabelMap[]
  checklist   TaskChecklist[]
  activities  TaskActivity[]
  watchers    TaskWatcher[]

  club   Club? @relation(fields: [clubId], references: [id])
  clubId Int?

  completedById Int?
  startedAt     DateTime?
  archivedAt    DateTime?

  extra Json?

  @@index([committeeId])
  @@index([assignedToId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
}

model TaskLabel {
  id    Int    @id @default(autoincrement())
  name  String
  color String

  clubId Int
  club   Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  tasks TaskLabelMap[]

  @@unique([clubId, name])
}

model TaskLabelMap {
  id Int @id @default(autoincrement())

  taskId Int

  labelId Int

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  label TaskLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([taskId, labelId])
}

model TaskChecklist {
  id Int @id @default(autoincrement())

  taskId Int

  title String

  completed Boolean @default(false)

  position Int @default(0)

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TaskActivity {
  id Int @id @default(autoincrement())

  taskId Int

  membershipId Int

  action String

  oldValue String?

  newValue String?

  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  membership Membership @relation(fields: [membershipId], references: [id])

  @@index([taskId])
}

model TaskWatcher {
  id Int @id @default(autoincrement())

  taskId Int

  membershipId Int

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  membership Membership @relation(fields: [membershipId], references: [id])

  @@unique([taskId, membershipId])
  @@index([membershipId])
}

model TaskComment {
  id Int @id @default(autoincrement())

  content String

  taskId       Int
  membershipId Int

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  editedAt  DateTime?
  deletedAt DateTime?

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  reactions TaskCommentReaction[]

  parentId Int?
  parent   TaskComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  TaskComment[] @relation("CommentReplies")

  @@index([taskId])
}

model TaskAttachment {
  id     Int @id @default(autoincrement())
  taskId Int

  membershipId Int

  fileUrl  String
  fileName String
  mimeType String
  size     Int

  uploadedAt DateTime  @default(now())
  deletedAt  DateTime?

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  membership Membership @relation(fields: [membershipId], references: [id])

  checksum String?

  storagePath String?

  bucket String?

  objectKey String?

  thumbnailUrl String?

  @@index([taskId])
}

model TaskCommentReaction {
  id Int @id @default(autoincrement())

  emoji String

  commentId Int

  membershipId Int

  createdAt DateTime @default(now())

  comment TaskComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([commentId, membershipId, emoji])
  @@index([membershipId])
}

model ChatRoom {
  id Int @id @default(autoincrement())

  name String?

  type ChatRoomType

  clubId Int?

  committeeId Int?

  lastMessageId Int?
  lastActivity  DateTime?

  archived Boolean @default(false)

  createdAt DateTime @default(now())

  club Club? @relation(fields: [clubId], references: [id])

  committee Committee? @relation(fields: [committeeId], references: [id])

  messages ChatMessage[]

  @@index([clubId])
  @@index([committeeId])
}

model ChatMessage {
  id Int @id @default(autoincrement())

  roomId Int

  membershipId Int

  content String?

  replyToId Int?
  replyTo   ChatMessage?  @relation("ReplyMessage", fields: [replyToId], references: [id])
  replies   ChatMessage[] @relation("ReplyMessage")

  edited   Boolean   @default(false)
  editedAt DateTime?

  searchVector String?

  editedById Int?

  version Int @default(1)

  deletedForAll Boolean   @default(false)
  deletedAt     DateTime?

  createdAt      DateTime  @default(now())
  deliveredAt    DateTime?
  updatedAt      DateTime  @updatedAt
  lastEditedById Int?

  isSystem Boolean @default(false)

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  reactions       ChatReaction[]
  reads           ChatRead[]
  deletedBy       DeletedChatMessage[]
  mentions        Mention[]
  threads         ChatThread[]
  user            User?                @relation(fields: [userId], references: [id])
  userId          Int?
  club            Club?                @relation(fields: [clubId], references: [id])
  clubId          Int?
  pin             ChatPin?
  starredBy       StarredMessage[]
  savedBy         SavedMessage[]
  attachments     ChatAttachment[]
  pinnedMessage   PinnedMessage?
  messageMetadata Json?

  @@index([roomId])
  @@index([membershipId])
  @@index([createdAt])
}

model ChatAttachment {
  id Int @id @default(autoincrement())

  messageId Int
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  fileUrl       String
  fileName      String
  fileType      String
  fileExtension String?
  fileSize      BigInt

  bucket String?

  objectKey String?

  mimeCategory FileCategory

  thumbnailUrl String?

  blurHash String?

  width  Int?
  height Int?

  duration Int?

  createdAt  DateTime @default(now())
  uploadedAt DateTime @default(now())

  checksum String?

  virusScanned Boolean @default(false)

  storageProvider String?
  storagePath     String?

  @@index([messageId])
}

model ChatPin {
  id Int @id @default(autoincrement())

  messageId Int @unique

  pinnedById Int

  reason String?

  createdAt DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  pinnedBy Membership @relation(fields: [pinnedById], references: [id])

  @@index([pinnedById])
}

model StarredMessage {
  id Int @id @default(autoincrement())

  membershipId Int
  messageId    Int

  createdAt DateTime @default(now())

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([membershipId, messageId])
  @@index([membershipId])
}

model SavedMessage {
  id Int @id @default(autoincrement())

  membershipId Int
  messageId    Int

  createdAt DateTime @default(now())

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([membershipId, messageId])
}

model ChatReaction {
  id Int @id @default(autoincrement())

  emoji String

  messageId Int

  membershipId Int

  createdAt DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([messageId, membershipId, emoji])
  @@index([membershipId])
}

model ChatRead {
  id Int @id @default(autoincrement())

  messageId Int

  membershipId Int

  readAt DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([messageId, membershipId])
}

model DeletedChatMessage {
  id Int @id @default(autoincrement())

  userId Int

  messageId Int

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId])
}

model ChatThread {
  id Int @id @default(autoincrement())

  rootMessageId Int

  membershipId Int

  content String?

  fileUrl  String?
  fileName String?
  fileType String?
  fileSize Int?

  parentThreadId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  edited   Boolean   @default(false)
  editedAt DateTime?

  deletedForAll Boolean   @default(false)
  deletedAt     DateTime?

  rootMessage ChatMessage @relation(fields: [rootMessageId], references: [id], onDelete: Cascade)

  membership Membership @relation(fields: [membershipId], references: [id])

  parentThread ChatThread? @relation("ThreadReplies", fields: [parentThreadId], references: [id])

  replyCount Int @default(0)

  replies ChatThread[] @relation("ThreadReplies")

  reactions ChatThreadReaction[]

  @@index([rootMessageId])
}

model ChatThreadReaction {
  id Int @id @default(autoincrement())

  threadId Int

  membershipId Int

  emoji String

  createdAt DateTime @default(now())

  thread ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  membership Membership @relation(fields: [membershipId], references: [id])

  @@unique([threadId, membershipId, emoji])
}

model Mention {
  id Int @id @default(autoincrement())

  messageId Int

  userId Int

  createdAt DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id])

  @@index([messageId])
  @@index([userId])
}

model PinnedMessage {
  id           Int @id @default(autoincrement())
  messageId    Int @unique
  membershipId Int

  pinnedAt DateTime @default(now())

  message    ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  membership Membership  @relation(fields: [membershipId], references: [id])
}

model AuditLog {
  id Int @id @default(autoincrement())

  action String

  entityType String?
  entityId Int?

  description String?
  clubId Int?

  performedById Int?

  metadata Json?

  createdAt DateTime @default(now())

  @@index([action])
  @@index([clubId])
  @@index([performedById])
}

model SearchHistory {
  id     Int    @id @default(autoincrement())
  userId Int
  query  String

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model UserSession {
  id     Int    @id @default(autoincrement())
  userId Int
  token  String

  ip      String?
  browser String?
  os      String?

  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model LoginHistory {
  id     Int @id @default(autoincrement())
  userId Int

  ip      String?
  browser String?
  success Boolean

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model UploadHistory {
  id           Int @id @default(autoincrement())
  membershipId Int

  fileName String
  fileUrl  String
  fileSize BigInt

  createdAt DateTime @default(now())

  membership Membership @relation(fields: [membershipId], references: [id])
}

model GoogleAccount {
  id     Int @id @default(autoincrement())
  userId Int @unique

  googleEmail String

  accessToken  String  @db.Text
  refreshToken String  @db.Text
  expiryDate   BigInt?

  scope String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ChatRoomType {
  CLUB
  COMMITTEE
  DIRECT
}

enum Role {
  GENERAL_VIEWER
  MEMBER
  COORDINATOR
  SUPER_ADMIN
}

enum MembershipStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  GENERAL
  CLUB
  EVENT
  RSVP
  ANNOUNCEMENT
  TASK
  MEETING
  CHAT
  SYSTEM
}

enum NotificationCategory {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ClubRole {
  MEMBER
  LEAD
  TREASURER
  SECRETARY
  PRESIDENT
}

enum ClubCategory {
  TECHNOLOGY
  CULTURAL
  SPORTS
  MUSIC
  ART
  LITERARY
  ENTREPRENEURSHIP
  RESEARCH
  SOCIAL
  FINANCE
  OTHER
}

enum RSVPStatus {
  GOING
  MAYBE
  NOT_GOING
}

enum CommitteeRole {
  MEMBER
  COORDINATOR
  HEAD
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  COMPLETED
