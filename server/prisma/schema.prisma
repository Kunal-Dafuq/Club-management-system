generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  Int                  @id @default(autoincrement())
  name                String
  email               String               @unique
  password            String
  department          String?
  role                Role                 @default(GENERAL_VIEWER)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  avatarUrl           String?
  bio                 String?
  isOnline            Boolean              @default(false)
  lastSeen            DateTime?
  phone               String?
  preferences         Json?
  googleAccessToken   String?
  googleRefreshToken  String?
  googleTokenExpiry   DateTime?
  activities          Activity[]
  announcements       Announcement[]
  auditLogs           AuditLog[]
  chatMessages        ChatMessage[]
  deletedChatMessages DeletedChatMessage[]
  eventsCreated       Event[]
  googleAccount       GoogleAccount?
  loginHistories      LoginHistory[]
  memberships         Membership[]
  mentions            Mention[]
  notifications       Notification[]
  rsvps               RSVP[]
  searchHistories     SearchHistory[]
  userSessions        UserSession[]
}

model Club {
  id             Int                 @id @default(autoincrement())
  name           String              @unique
  description    String?
  createdAt      DateTime            @default(now())
  about          String?
  accentColor    String              @default("#60a5fa")
  bannerUrl      String?
  category       ClubCategory        @default(OTHER)
  discord        String?
  email          String?
  established    Int?
  foundedBy      String?
  github         String?
  instagram      String?
  isRecruiting   Boolean             @default(true)
  linkedin       String?
  location       String?
  logoUrl        String?
  motto          String?
  primaryColor   String              @default("#2563eb")
  secondaryColor String              @default("#1d4ed8")
  slug           String?             @unique
  tagline        String?
  updatedAt      DateTime?
  verified       Boolean             @default(false)
  verifiedAt     DateTime?
  website        String?
  youtube        String?
  chatEnabled    Boolean             @default(true)
  coverVideo     String?
  deletedAt      DateTime?
  eventCount     Int                 @default(0)
  features       Json?
  memberCount    Int                 @default(0)
  settings       Json?
  taskEnabled    Boolean             @default(true)
  activities     Activity[]
  announcements  Announcement[]
  auditLogs      AuditLog[]
  chatMessages   ChatMessage[]
  chatRooms      ChatRoom[]
  tags           ClubTagAssignment[]
  committees     Committee[]
  events         Event[]
  memberships    Membership[]
  tasks          Task[]
  taskLabels     TaskLabel[]
}

model ClubTag {
  id    Int                 @id @default(autoincrement())
  name  String              @unique
  clubs ClubTagAssignment[]
}

model ClubTagAssignment {
  clubId Int
  tagId  Int
  club   Club    @relation(fields: [clubId], references: [id])
  tag    ClubTag @relation(fields: [tagId], references: [id])

  @@id([clubId, tagId])
}

model Committee {
  id          Int                @id @default(autoincrement())
  name        String
  description String?
  color       String?            @default("#2563eb")
  icon        String?
  isCore      Boolean            @default(false)
  clubId      Int
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  deletedAt   DateTime?
  order       Int                @default(0)
  chatRooms   ChatRoom[]
  club        Club               @relation(fields: [clubId], references: [id], onDelete: Cascade)
  meetings    CommitteeMeeting[]
  members     CommitteeMember[]
  tasks       Task[]

  @@unique([clubId, name])
  @@index([clubId])
}

model CommitteeMember {
  id            Int           @id @default(autoincrement())
  committeeId   Int
  membershipId  Int
  role          CommitteeRole @default(MEMBER)
  joinedAt      DateTime      @default(now())
  committee     Committee     @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  membership    Membership    @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  assignedTasks Task[]        @relation("TaskAssignment")

  @@unique([committeeId, membershipId])
  @@index([membershipId])
  @@index([committeeId])
}

model MeetingSummary {
  id            Int              @id @default(autoincrement())
  meetingId     Int              @unique
  summary       String
  transcript    String?
  actionItems   Json?
  decisions     Json?
  createdAt     DateTime         @default(now())
  generatedByAI Boolean          @default(true)
  nextSteps     Json?
  updatedAt     DateTime         @updatedAt
  meeting       CommitteeMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model CommitteeMeeting {
  id              Int                 @id @default(autoincrement())
  title           String
  description     String?
  startTime       DateTime
  endTime         DateTime?
  location        String?
  onlineLink      String?
  committeeId     Int
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?
  agenda          String?
  calendarEventId String?
  isInstant       Boolean             @default(false)
  meetingCode     String?
  meetingProvider MeetingProvider     @default(GOOGLE_MEET)
  organizerId     Int
  status          MeetingStatus       @default(SCHEDULED)
  aiSummaryStatus SummaryStatus       @default(PENDING)
  committee       Committee           @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  organizer       Membership          @relation("MeetingOrganizer", fields: [organizerId], references: [id])
  attachments     MeetingAttachment[]
  attendees       MeetingAttendance[]
  notes           MeetingNote[]
  polls           MeetingPoll[]
  recordings      MeetingRecording[]
  summaries       MeetingSummary?

  @@index([committeeId])
  @@index([startTime])
  @@index([status])
}

model MeetingAttendance {
  id           Int                     @id @default(autoincrement())
  meetingId    Int
  membershipId Int
  status       MeetingAttendanceStatus @default(PENDING)
  duration     Int?
  joinedAt     DateTime?
  leftAt       DateTime?
  meeting      CommitteeMeeting        @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  membership   Membership              @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([meetingId, membershipId])
}

model MeetingNote {
  id           Int              @id @default(autoincrement())
  meetingId    Int
  membershipId Int
  note         String
  createdAt    DateTime         @default(now())
  meeting      CommitteeMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  membership   Membership       @relation(fields: [membershipId], references: [id])
}

model MeetingRecording {
  id           Int              @id @default(autoincrement())
  meetingId    Int
  recordingUrl String
  bucket String?
  objectKey String?
  fileSize Int?
  mimeType String?
  duration Int?
  checksum String?
  uploadedAt DateTime @default(now())
  duration     Int?
  createdAt    DateTime         @default(now())
  meeting      CommitteeMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model MeetingAttachment {
  id              Int              @id @default(autoincrement())
  meetingId       Int
  uploadedById    Int
  fileName        String
  fileUrl         String
  storageProvider String?
  bucket          String?
  storagePath     String?
  checksum        String?
  mimeType        String?
  size            Int?
  createdAt       DateTime         @default(now())
  meeting         CommitteeMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  uploader        Membership       @relation(fields: [uploadedById], references: [id])
}

model MeetingPoll {
  id             Int                 @id @default(autoincrement())
  meetingId      Int
  question       String
  multipleChoice Boolean             @default(false)
  createdById    Int
  isClosed       Boolean             @default(false)
  createdAt      DateTime            @default(now())
  creator        Membership          @relation(fields: [createdById], references: [id])
  meeting        CommitteeMeeting    @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  options        MeetingPollOption[]
}

model MeetingPollOption {
  id     Int         @id @default(autoincrement())
  pollId Int
  option String
  votes  Int         @default(0)
  poll   MeetingPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
}

model Membership {
  id                   Int                   @id @default(autoincrement())
  userId               Int
  clubId               Int
  joinedAt             DateTime              @default(now())
  clubRole             ClubRole              @default(MEMBER)
  status               MembershipStatus      @default(PENDING)
  joinedById           Int?
  lastVisitedAt        DateTime?
  muteNotifications    Boolean               @default(false)
  nickname             String?
  leftAt               DateTime?
  chatMessages         ChatMessage[]
  chatPins             ChatPin[]
  chatReactions        ChatReaction[]
  chatReads            ChatRead[]
  chatThreads          ChatThread[]
  chatThreadReactions  ChatThreadReaction[]
  organizedMeetings    CommitteeMeeting[]    @relation("MeetingOrganizer")
  committeeMemberships CommitteeMember[]
  meetingAttachments   MeetingAttachment[]
  meetingAttendances   MeetingAttendance[]
  meetingNotes         MeetingNote[]
  meetingPolls         MeetingPoll[]
  club                 Club                  @relation(fields: [clubId], references: [id])
  user                 User                  @relation(fields: [userId], references: [id])
  pinnedMessages       PinnedMessage[]
  savedMessages        SavedMessage[]
  starredMessages      StarredMessage[]
  createdTasks         Task[]                @relation("TaskCreator")
  taskActivities       TaskActivity[]
  attachments          TaskAttachment[]
  taskComments         TaskComment[]
  commentReactions     TaskCommentReaction[]
  watchedTasks         TaskWatcher[]
  uploadHistories      UploadHistory[]

  @@unique([userId, clubId])
}

model Event {
  id          Int       @id @default(autoincrement())
  title       String
  description String
  startTime   DateTime
  endTime     DateTime
  location    String
  visibility  Boolean   @default(true)
  clubId      Int
  createdById Int
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?
  club        Club      @relation(fields: [clubId], references: [id])
  creator     User      @relation(fields: [createdById], references: [id])
  rsvps       RSVP[]

  @@index([clubId])
  @@index([createdById])
  @@index([startTime])
}

model RSVP {
  id        Int        @id @default(autoincrement())
  userId    Int
  eventId   Int
  status    RSVPStatus
  createdAt DateTime   @default(now())
  event     Event      @relation(fields: [eventId], references: [id])
  user      User       @relation(fields: [userId], references: [id])

  @@unique([userId, eventId])
}

model Notification {
  id          Int                  @id @default(autoincrement())
  message     String
  userId      Int
  createdAt   DateTime             @default(now())
  icon        String?
  metadata    Json?
  title       String
  actionText  String?
  actionUrl   String?
  category    NotificationCategory
  clubId      Int?
  deliveredAt DateTime?
  entityId    Int?
  entityType  String?
  expiresAt   DateTime?
  imageUrl    String?
  isRead      Boolean              @default(false)
  priority    NotificationPriority @default(NORMAL)
  readAt      DateTime?
  senderId    Int?
  type        NotificationType
  user        User                 @relation(fields: [userId], references: [id])
}

model Announcement {
  id          Int      @id @default(autoincrement())
  title       String
  content     String
  clubId      Int
  createdById Int
  createdAt   DateTime @default(now())
  club        Club     @relation(fields: [clubId], references: [id])
  creator     User     @relation(fields: [createdById], references: [id])
}

model Activity {
  id          Int      @id @default(autoincrement())
  action      String
  description String
  clubId      Int
  userId      Int?
  createdAt   DateTime @default(now())
  entityId    Int?
  entityType  String?
  metadata    Json?
  club        Club     @relation(fields: [clubId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])

  @@index([clubId])
  @@index([createdAt])
}

model Task {
  id             Int              @id @default(autoincrement())
  title          String
  description    String?
  status         TaskStatus       @default(TODO)
  priority       TaskPriority     @default(MEDIUM)
  dueDate        DateTime?
  completedAt    DateTime?
  estimatedHours Float?
  position       Int              @default(0)
  isArchived     Boolean          @default(false)
  committeeId    Int
  assignedToId   Int?
  createdById    Int
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  clubId         Int?
  archivedAt     DateTime?
  completedById  Int?
  deletedAt      DateTime?
  extra          Json?
  startedAt      DateTime?
  assignedTo     CommitteeMember? @relation("TaskAssignment", fields: [assignedToId], references: [id])
  club           Club?            @relation(fields: [clubId], references: [id])
  committee      Committee        @relation(fields: [committeeId], references: [id])
  createdBy      Membership       @relation("TaskCreator", fields: [createdById], references: [id])
  activities     TaskActivity[]
  attachments    TaskAttachment[]
  checklist      TaskChecklist[]
  comments       TaskComment[]
  labels         TaskLabelMap[]
  watchers       TaskWatcher[]

  @@index([committeeId])
  @@index([assignedToId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
}

model TaskLabel {
  id     Int            @id @default(autoincrement())
  name   String
  color  String
  clubId Int
  club   Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  tasks  TaskLabelMap[]

  @@unique([clubId, name])
}

model TaskLabelMap {
  id      Int       @id @default(autoincrement())
  taskId  Int
  labelId Int
  label   TaskLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)
  task    Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, labelId])
}

model TaskChecklist {
  id        Int     @id @default(autoincrement())
  taskId    Int
  title     String
  completed Boolean @default(false)
  position  Int     @default(0)
  task      Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TaskActivity {
  id           Int        @id @default(autoincrement())
  taskId       Int
  membershipId Int
  action       String
  oldValue     String?
  newValue     String?
  createdAt    DateTime   @default(now())
  membership   Membership @relation(fields: [membershipId], references: [id])
  task         Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TaskWatcher {
  id           Int        @id @default(autoincrement())
  taskId       Int
  membershipId Int
  membership   Membership @relation(fields: [membershipId], references: [id])
  task         Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, membershipId])
  @@index([membershipId])
}

model TaskComment {
  id           Int                   @id @default(autoincrement())
  content      String
  taskId       Int
  membershipId Int
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  editedAt     DateTime?
  parentId     Int?
  deletedAt    DateTime?
  membership   Membership            @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  parent       TaskComment?          @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies      TaskComment[]         @relation("CommentReplies")
  task         Task                  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  reactions    TaskCommentReaction[]

  @@index([taskId])
}

model TaskAttachment {
  id           Int        @id @default(autoincrement())
  fileName     String
  fileUrl      String
  taskId       Int
  membershipId Int
  uploadedAt   DateTime   @default(now())
  mimeType     String
  size         Int
  checksum     String?
  storagePath  String?
  thumbnailUrl String?
  bucket       String?
  deletedAt    DateTime?
  objectKey    String?
  membership   Membership @relation(fields: [membershipId], references: [id])
  task         Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TaskCommentReaction {
  id           Int         @id @default(autoincrement())
  emoji        String
  commentId    Int
  membershipId Int
  createdAt    DateTime    @default(now())
  comment      TaskComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  membership   Membership  @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([commentId, membershipId, emoji])
  @@index([membershipId])
}

model ChatRoom {
  id            Int           @id @default(autoincrement())
  name          String?
  type          ChatRoomType
  clubId        Int?
  committeeId   Int?
  createdAt     DateTime      @default(now())
  archived      Boolean       @default(false)
  lastActivity  DateTime?
  lastMessageId Int?
  messages      ChatMessage[]
  club          Club?         @relation(fields: [clubId], references: [id])
  committee     Committee?    @relation(fields: [committeeId], references: [id])

  @@index([clubId])
  @@index([committeeId])
}

model ChatMessage {
  id              Int                  @id @default(autoincrement())
  roomId          Int
  membershipId    Int
  content         String?
  replyToId       Int?
  editedAt        DateTime?
  createdAt       DateTime             @default(now())
  clubId          Int?
  userId          Int?
  edited          Boolean              @default(false)
  updatedAt       DateTime             @updatedAt
  deletedForAll   Boolean              @default(false)
  deletedAt       DateTime?
  deliveredAt     DateTime?
  isSystem        Boolean              @default(false)
  lastEditedById  Int?
  editedById      Int?
  messageMetadata Json?
  searchVector    String?
  version         Int                  @default(1)
  attachments     ChatAttachment[]
  club            Club?                @relation(fields: [clubId], references: [id])
  membership      Membership           @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  replyTo         ChatMessage?         @relation("ReplyMessage", fields: [replyToId], references: [id])
  replies         ChatMessage[]        @relation("ReplyMessage")
  room            ChatRoom             @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user            User?                @relation(fields: [userId], references: [id])
  pin             ChatPin?
  reactions       ChatReaction[]
  reads           ChatRead[]
  threads         ChatThread[]
  deletedBy       DeletedChatMessage[]
  mentions        Mention[]
  pinnedMessage   PinnedMessage?
  savedBy         SavedMessage[]
  starredBy       StarredMessage[]

  @@index([roomId])
  @@index([membershipId])
  @@index([createdAt])
}

model ChatAttachment {
  id              Int          @id @default(autoincrement())
  messageId       Int
  fileUrl         String
  fileName        String
  fileType        String
  fileExtension   String?
  fileSize        BigInt
  mimeCategory    FileCategory
  thumbnailUrl    String?
  uploadedAt      DateTime     @default(now())
  createdAt       DateTime     @default(now())
  duration        Int?
  height          Int?
  width           Int?
  blurHash        String?
  checksum        String?
  storagePath     String?
  storageProvider String?
  virusScanned    Boolean      @default(false)
  bucket          String?
  objectKey       String?
  message         ChatMessage  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model ChatPin {
  id         Int         @id @default(autoincrement())
  messageId  Int         @unique
  pinnedById Int
  reason     String?
  createdAt  DateTime    @default(now())
  message    ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pinnedBy   Membership  @relation(fields: [pinnedById], references: [id])

  @@index([pinnedById])
}

model StarredMessage {
  id           Int         @id @default(autoincrement())
  membershipId Int
  messageId    Int
  createdAt    DateTime    @default(now())
  membership   Membership  @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  message      ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([membershipId, messageId])
  @@index([membershipId])
}

model SavedMessage {
  id           Int         @id @default(autoincrement())
  membershipId Int
  messageId    Int
  createdAt    DateTime    @default(now())
  membership   Membership  @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  message      ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([membershipId, messageId])
}

model ChatReaction {
  id           Int         @id @default(autoincrement())
  messageId    Int
  membershipId Int
  emoji        String
  createdAt    DateTime    @default(now())
  membership   Membership  @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  message      ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, membershipId, emoji])
  @@index([membershipId])
}

model ChatRead {
  id           Int         @id @default(autoincrement())
  messageId    Int
  membershipId Int
  readAt       DateTime    @default(now())
  membership   Membership  @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  message      ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, membershipId])
}

model DeletedChatMessage {
  id        Int         @id @default(autoincrement())
  userId    Int
  messageId Int
  createdAt DateTime    @default(now())
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id])

  @@unique([userId, messageId])
}

model ChatThread {
  id             Int                  @id @default(autoincrement())
  rootMessageId  Int
  membershipId   Int
  content        String?
  fileUrl        String?
  fileName       String?
  fileType       String?
  fileSize       Int?
  parentThreadId Int?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  edited         Boolean              @default(false)
  editedAt       DateTime?
  deletedForAll  Boolean              @default(false)
  deletedAt      DateTime?
  replyCount     Int                  @default(0)
  membership     Membership           @relation(fields: [membershipId], references: [id])
  parentThread   ChatThread?          @relation("ThreadReplies", fields: [parentThreadId], references: [id])
  replies        ChatThread[]         @relation("ThreadReplies")
  rootMessage    ChatMessage          @relation(fields: [rootMessageId], references: [id], onDelete: Cascade)
  reactions      ChatThreadReaction[]

  @@index([rootMessageId])
}

model ChatThreadReaction {
  id           Int        @id @default(autoincrement())
  threadId     Int
  membershipId Int
  emoji        String
  createdAt    DateTime   @default(now())
  membership   Membership @relation(fields: [membershipId], references: [id])
  thread       ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([threadId, membershipId, emoji])
}

model Mention {
  id        Int         @id @default(autoincrement())
  messageId Int
  userId    Int
  createdAt DateTime    @default(now())
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id])

  @@index([messageId])
  @@index([userId])
}

model PinnedMessage {
  id           Int         @id @default(autoincrement())
  messageId    Int         @unique
  membershipId Int
  pinnedAt     DateTime    @default(now())
  membership   Membership  @relation(fields: [membershipId], references: [id])
  message      ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id            Int      @id @default(autoincrement())
  userId        Int?
  clubId        Int?
  action        String
  entityId      Int?
  metadata      Json?
  createdAt     DateTime @default(now())
  description   String?
  entityType    String?
  performedById Int?
  club          Club?    @relation(fields: [clubId], references: [id])
  user          User?    @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([clubId])
  @@index([performedById])
}

model SearchHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  query     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model UserSession {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String
  ip        String?
  browser   String?
  os        String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model LoginHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  ip        String?
  browser   String?
  success   Boolean
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model UploadHistory {
  id           Int        @id @default(autoincrement())
  membershipId Int
  fileName     String
  fileUrl      String
  fileSize     BigInt
  createdAt    DateTime   @default(now())
  membership   Membership @relation(fields: [membershipId], references: [id])
}

model GoogleAccount {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  googleEmail  String
  accessToken  String
  refreshToken String
  expiryDate   BigInt?
  scope        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

